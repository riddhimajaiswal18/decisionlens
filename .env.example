APP_NAME=DecisionLens
APP_ENV=development
API_V1_PREFIX=/api/v1
# Used by the React dashboard when running it outside Docker.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Required for query intelligence and the demo seed pipeline.
SUPERMEMORY_BASE_URL=
SUPERMEMORY_API_KEY=
SUPERMEMORY_CONTAINER_TAG=decisionlens
SUPERMEMORY_TIMEOUT_SECONDS=30
SUPERMEMORY_MAX_RETRIES=3
SUPERMEMORY_RETRY_BASE_SECONDS=0.25
SUPERMEMORY_BATCH_SIZE=100
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
